NAS_DATABASE_URL=sqlite:///./data/novel_agent_studio.db
NAS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
NAS_ALLOWED_HOSTS=127.0.0.1,localhost
NAS_ENV=development
NAS_LOG_DIR=./data/logs
NAS_LOG_RETENTION_DAYS=14
NAS_MAX_BACKUP_BYTES=268435456
NAS_MAX_BACKUP_UNCOMPRESSED_BYTES=1073741824
NAS_MOCK_DELAY_MS=40
# Store only this variable name in the database, never the secret value.
OPENAI_API_KEY=replace-with-your-key-if-needed
